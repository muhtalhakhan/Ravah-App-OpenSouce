# Application Settings
APP_NAME=FullStack Agent App
APP_VERSION=1.0.0
DEBUG=True

# Server Configuration
HOST=0.0.0.0
PORT=8000

# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agentapp

# JWT Authentication
JWT_SECRET_KEY=your-secret-key-change-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
AUTH_PROVIDER=local

# CORS Origins (comma-separated)
CORS_ORIGINS=["http://localhost:4321","http://localhost:3000"]

# Agent Framework Selection (crewai, agno, or langchain)
AGENT_FRAMEWORK=crewai

# OpenAI API Configuration
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-3.5-turbo
AGENT_MOCK_MODE=True

# Redis (optional)
REDIS_URL=redis://localhost:6379/0

# Google AI / Gemini — used by `python cli.py generate` for post generation
GOOGLE_API_KEY=your-google-ai-api-key-here
GOOGLE_AI_MODEL=gemini-2.5-flash-preview-04-17

# Supabase (optional)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
